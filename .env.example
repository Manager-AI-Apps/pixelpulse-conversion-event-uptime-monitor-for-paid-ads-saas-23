# Default placeholders. Build Engine appends plan-required env vars below.

# Postgres connection string (set per-build by Deployer)
DATABASE_URL=

# Better Auth session secret (auto-generated per build; min 32 chars)
BETTER_AUTH_SECRET=

# Better Auth base URL (the app's public origin; set per-build by Deployer)
BETTER_AUTH_URL=

# Google OAuth credentials — every app ships "Continue with Google".
# Supplied by a human at the approval gate, injected at deploy time.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required by plan
# Slack incoming webhook URL for alert delivery (secret)
SLACK_WEBHOOK_URL=

# Bearer token required on GET /api/monitor/run to prevent unauthorized cron triggers (secret)
CRON_SECRET=

# Public base URL of the deployed app (used in snippet JS src)
NEXT_PUBLIC_APP_URL=
